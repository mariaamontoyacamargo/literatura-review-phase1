# Literatura Review Phase 1 - API Keys & Configuration
# Copy this to .env and fill in your actual credentials
# NEVER commit .env to git

# SerpAPI (Google Scholar searches)
SERPAPI_KEY=your_serpapi_key_here

# Twitter/X API (Tweepy)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Output paths
DATA_DIR=./data
OUTPUT_DIR=./outputs
SCRIPTS_DIR=./scripts

# Logging
LOG_LEVEL=INFO
LOG_FILE=./outputs/logs.txt

# Rate limiting
API_RETRY_ATTEMPTS=3
API_RETRY_BACKOFF_EXPONENTIAL=true
